<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nayana & Abhinav Wedding Invitation</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        /* 
           THEME STYLES (To change styles, swap the colors in :root)
           
           Option 1: Royal Emerald & Gold (Active)
           --primary: #064e3b; --secondary: #b45309; --accent: #f59e0b; --bg: #fcfbf7;
           
           Option 2: Blush Rose & Champagne
           --primary: #654343; --secondary: #b97a7a; --accent: #d4af37; --bg: #fffafb;
           
           Option 3: Deep Burgundy & Ivory
           --primary: #4a0e17; --secondary: #800020; --accent: #dfba6b; --bg: #fdfaf6;
        */

        :root {
            --primary: #064e3b; /* Deep Emerald */
            --secondary: #b45309; /* Warm Gold/Amber */
            --accent: #d97706;
            --bg: #fcfbf7; /* Off-white/Ivory */
            --text: #1f2937;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            text-align: center;
            overflow-x: hidden;
        }

        h1, h2, h3, .script-font {
            font-family: 'Cinzel', serif;
            letter-spacing: 2px;
        }

        /* Hero Section */
        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: linear-gradient(rgba(6, 78, 59, 0.4), rgba(6, 78, 59, 0.7)), 
                        url('https://drive.google.com/file/d/1R11RSkOllWltZsMzXuxRJKGHtA70GfVg/view?usp=drive_link') center/cover no-repeat;
            color: white;
            padding: 20px;
        }

        .hero h2 {
            font-size: 1.5rem;
            text-transform: uppercase;
            margin-bottom: 10px;
            color: #f3f4f6;
        }

        .hero h1 {
            font-size: 3.5rem;
            margin: 20px 0;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }

        .hero p {
            font-size: 1.2rem;
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        /* Couples Section with AI Portraits */
        .couple-section {
            padding: 80px 20px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .couple-container {
            display: flex;
            justify-content: space-around;
            align-items: center;
            flex-wrap: wrap;
            margin-top: 40px;
            gap: 30px;
        }

        .profile-card {
            flex: 1;
            min-width: 280px;
            max-width: 350px;
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            border: 1px solid rgba(180, 83, 9, 0.2);
            transition: transform 0.3s ease;
        }

        .profile-card:hover {
            transform: translateY(-5px);
        }

        .profile-card img {
            width: 100%;
            height: 400px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 20px;
        }

        .profile-card h3 {
            color: var(--primary);
            font-size: 1.8rem;
            margin-bottom: 5px;
        }

        .ampersand {
            font-size: 3rem;
            color: var(--secondary);
            align-self: center;
        }

        /* Countdown Section */
        .countdown-section {
            background-color: var(--primary);
            color: white;
            padding: 60px 20px;
        }

        .countdown-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 30px;
        }

        .countdown-box {
            background: rgba(255, 255, 255, 0.1);
            padding: 20px;
            border-radius: 10px;
            min-width: 90px;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,255,255,0.2);
        }

        .countdown-box span {
            display: block;
            font-size: 2.5rem;
            font-weight: bold;
            font-family: 'Cinzel', serif;
            color: var(--secondary);
        }

        /* Events Section */
        .events-section {
            padding: 80px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .events-grid {
            display: flex;
            justify-content: center;
            gap: 40px;
            flex-wrap: wrap;
            margin-top: 40px;
        }

        .event-card {
            background: white;
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            flex: 1;
            min-width: 320px;
            max-width: 500px;
            border-top: 5px solid var(--primary);
        }

        .event-card h3 {
            color: var(--primary);
            margin-bottom: 15px;
            font-size: 1.8rem;
        }

        .event-details {
            margin: 20px 0;
            line-height: 1.6;
        }

        .btn {
            display: inline-block;
            padding: 12px 25px;
            background-color: var(--primary);
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 500;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            margin: 10px 5px;
            border: 1px solid var(--primary);
        }

        .btn:hover {
            background-color: transparent;
            color: var(--primary);
        }

        .btn-secondary {
            background-color: transparent;
            color: var(--secondary);
            border: 1px solid var(--secondary);
        }

        .btn-secondary:hover {
            background-color: var(--secondary);
            color: white;
        }

        footer {
            padding: 40px;
            background: #1f2937;
            color: #9ca3af;
            font-size: 0.9rem;
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
            .ampersand { transform: rotate(90deg); margin: 10px 0; }
            .countdown-container { gap: 10px; }
            .countdown-box { min-width: 70px; padding: 10px; }
            .countdown-box span { font-size: 1.8rem; }
        }
    </style>
</head>
<body>

    <!-- Hero Section -->
    <section class="hero">
        <h2>Are Together Welcoming You To Their Wedding</h2>
        <h1>Nayana & Abhinav</h1>
        <p>August 23, 2026</p>
    </section>

    <!-- Couple Portraits Section -->
    <section class="couple-section">
        <h2>The Happy Couple</h2>
        <div class="couple-container">
            <div class="profile-card">
                <!-- Sample AI Traditional Bride Portrait Placeholder -->
                <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?q=80&w=600" alt="Bride Nayana">
                <h3>Nayana</h3>
                <p>The Beautiful Bride</p>
            </div>
            
            <div class="ampersand">&</div>
            
            <div class="profile-card">
                <!-- Sample AI Traditional Groom Portrait Placeholder -->
                <img src="https://images.unsplash.com/photo-1605001011156-cbf0b0f67a51?q=80&w=600" alt="Groom Abhinav">
                <h3>Abhinav</h3>
                <p>The Handsome Groom</p>
            </div>
        </div>
    </section>

    <!-- Countdown Section -->
    <section class="countdown-section">
        <h2>Counting Down To The Big Day</h2>
        <div class="countdown-container">
            <div class="countdown-box">
                <span id="days">00</span>
                Days
            </div>
            <div class="countdown-box">
                <span id="hours">00</span>
                Hours
            </div>
            <div class="countdown-box">
                <span id="minutes">00</span>
                Mins
            </div>
            <div class="countdown-box">
                <span id="seconds">00</span>
                Secs
            </div>
        </div>
    </section>

    <!-- Events & Venues Section -->
    <section class="events-section">
        <h2>Wedding Events</h2>
        <div class="events-grid">
            
            <!-- Muhurtham Card -->
            <div class="event-card">
                <h3>Wedding Muhurtham</h3>
                <div class="event-details">
                    <p><strong>Date:</strong> Sunday, 23rd August 2026</p>
                    <p><strong>Time:</strong> 10:30 AM - 11:30 AM</p>
                    <p><strong>Venue:</strong> Meenakshi Mahal</p>
                    <p style="font-size: 0.85rem; color:#6b7280;">PPJG+97P, Polpully, Kerala 678552</p>
                </div>
                <a href="https://maps.google.com/?q=Meenakshi+Mahal+Polpully+Kerala" target="_blank" class="btn">View Map</a>
                <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Nayana+%26+Abhinav+Wedding+Muhurtham&dates=20260823T050000Z/20260823T060000Z&details=Wedding+Muhurtham+of+Nayana+and+Abhinav&location=Meenakshi+Mahal,+Polpully,+Kerala+678552" target="_blank" class="btn btn-secondary">Add to Calendar</a>
            </div>

            <!-- Reception Card -->
            <div class="event-card">
                <h3>Wedding Reception</h3>
                <div class="event-details">
                    <p><strong>Date:</strong> Sunday, 23rd August 2026</p>
                    <p><strong>Time:</strong> 05:00 PM Onwards</p>
                    <p><strong>Venue:</strong> Mohamed Bagh Event Centre</p>
                    <p style="font-size: 0.85rem; color:#6b7280;">Sulaiman Sahib Rd, opposite Elegant Public School, behind Mangalam Towers, Valakkad, Palakkad, Kerala 678014</p>
                </div>
                <a href="https://maps.google.com/?q=Mohamed+Bagh+Event+Centre+Palakkad" target="_blank" class="btn">View Map</a>
                <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Nayana+%26+Abhinav+Wedding+Reception&dates=20260823T113000Z/20260823T153000Z&details=Wedding+Reception+of+Nayana+and+Abhinav&location=Mohamed+Bagh+Event+Centre,+Valakkad,+Palakkad,+Kerala+678014" target="_blank" class="btn btn-secondary">Add to Calendar</a>
            </div>

        </div>
    </section>

    <footer>
        <p>We await your presence to bless our new journey.</p>
        <p style="margin-top: 10px; font-size: 0.75rem;">© 2026 Nayana & Abhinav</p>
    </footer>

    <!-- Countdown Timer Script -->
    <script>
        const weddingDate = new Date("August 23, 2026 10:30:00").getTime();

        const timer = setInterval(function() {
            const now = new Date().getTime();
            const distance = weddingDate - now;

            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            document.getElementById("days").innerHTML = days < 10 ? "0" + days : days;
            document.getElementById("hours").innerHTML = hours < 10 ? "0" + hours : hours;
            document.getElementById("minutes").innerHTML = minutes < 10 ? "0" + minutes : minutes;
            document.getElementById("seconds").innerHTML = seconds < 10 ? "0" + seconds : seconds;

            if (distance < 0) {
                clearInterval(timer);
                document.querySelector(".countdown-container").innerHTML = "<h3>The Celebration Has Begun!</h3>";
            }
        }, 1000);
    </script>
</body>
</html>
